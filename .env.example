# BrightData — Option 1: Scraping Browser (RECOMMENDED)
# Cloud browser with auto proxy rotation + anti-detection + CAPTCHA solving
# Get the endpoint from: BrightData Dashboard > Scraping Browser > Access Parameters
SBR_WS_ENDPOINT=wss://brd-customer-XXXXX-zone-XXXXX:PASSWORD@brd.superproxy.io:9222

# BrightData — Option 2: Residential Proxy (fallback)
# BRIGHTDATA_USERNAME=brd-customer-XXXXX-zone-XXXXX
# BRIGHTDATA_PASSWORD=your_password
# BRIGHTDATA_HOST=brd.superproxy.io
# BRIGHTDATA_PORT=22225

# Optional: custom database path (defaults to ./linkedin_ads.db)
# DB_PATH=./linkedin_ads.db
